# Host-side values for running the gate/tests on the host (and the reference CI mirrors).
# The `docker compose up` dev stack does NOT read this file — it injects its own
# container-networked env (DB host = the `postgres` service, servers bound to 0.0.0.0).
#
# API server — required by apps/api (no in-code defaults; these are suggested local
# values). The web dev-server also reads API_HOST/API_PORT as its /api proxy target.
API_HOST=127.0.0.1
API_PORT=3000
# Postgres DSN — matches docker-compose.yml (postgres service)
DATABASE_URL=postgres://jailu:jailu@127.0.0.1:5432/jailu

# Web dev server (vite + playwright)
WEB_HOST=127.0.0.1
WEB_PORT=5173
